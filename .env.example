# --- LLM (LM Studio, OpenAI-compatible API) ---
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=gemma-4-e4b
OPENAI_API_KEY=lm-studio

# --- TTS (Kokoro, local) ---
KOKORO_MODEL=kokoro-v1.0.onnx
KOKORO_VOICES=voices-v1.0.bin
KOKORO_VOICE=af_heart

# --- Pipeline limits ---
MAX_ARTICLES_PER_FEED=5
MAX_ARTICLES_TOTAL=20

# --- Scheduler (24h clock) ---
SCHEDULE_HOUR=6

# --- Cross-episode memory ---
# How many days of past story threads to recall as context for a new episode
MEMORY_WINDOW_DAYS=14

# --- Storage ---
AUDIO_DIR=audio
DB_PATH=inkcast.db

# --- Podcast feed metadata ---
FEED_TITLE=Inkcast
FEED_DESCRIPTION=Your daily personal briefing
FEED_BASE_URL=http://localhost:8000

# --- RSS sources (JSON array, single line) ---
# Used to seed the feeds table on first run only. After that, manage feeds
# via the /api/feeds endpoints (the DB is the source of truth).
FEED_URLS=["https://techcrunch.com/feed/","https://feeds.arstechnica.com/arstechnica/index","https://www.theverge.com/rss/index.xml","https://rss.nytimes.com/services/xml/rss/nyt/Technology.xml","https://www.wired.com/feed/rss","https://venturebeat.com/feed/"]
